"use client";

export default function RecommendationCard({
  recommendation,
  explanation,
  confidence,
  cheaper,
  recUrl,
  aiActive,
  mode,
  setMode
}: any) {

  if (!recommendation) return null;

  // ✅ SIMPLE RATING FIX
  const rating =
    Number(recommendation?.bestPick?.rating) > 0
      ? Number(recommendation.bestPick.rating)
      : 3.5;
	
  return (
  
  <div style={{
    background: "#000000", 	   // ✅ HERE
    padding: "24px",
    marginBottom: "24px",
    borderRadius: "20px",
    backdropFilter: "blur(12px)",           // ✅ HERE
 border: "none",
boxShadow: "0 20px 50px rgba(0,0,0,0.6)",
transition: "all 0.25s ease"
  }}
  onMouseOver={(e) => {
  e.currentTarget.style.transform = "translateY(-2px)";
}}
onMouseOut={(e) => {
  e.currentTarget.style.transform = "translateY(0)";
}}
  >

    {/* HEADER */}
    <div style={{ display: "flex", flexDirection: "column", gap: "4px" }}>
      <div style={{
        display: "inline-flex",
        alignItems: "center",
        gap: "8px",
//background: "rgba(56,189,248,0.15)",
background: "#000000", 
color: "#38bdf8",
        padding: "6px 12px",
        borderRadius: "999px",
        fontSize: "12px",
        fontWeight: "600"
      }}>
        ✨ Smart Buy
      </div>

      <div style={{
        fontSize: "18px",
fontWeight: "600",
color: "#f8fafc"
      }}>
        Best choice for your search
      </div>
    </div>
{/* 🏆 GOLD BADGE */}
<div style={{
  display: "flex",
  justifyContent: "left",
  marginTop: "16px"
}}>
  <div style={{
    position: "relative",
    width: "160px",
    height: "180px"
  }}>


    {/* TEXT INSIDE BADGE */}
    <div style={{
      position: "absolute",
      top: "45%",
      left: "50%",
      transform: "translate(-50%, -50%)",
      textAlign: "left",
      fontWeight: "700",
      color: "#5a3e00",
      fontSize: "13px",
      lineHeight: "1.3"
    }}>
      🏆 Best Recommendation
    </div>
  </div>
</div>
    {/* PRODUCT */}
    <div style={{
      marginTop: "16px",
      padding: "14px",
      borderRadius: "12px",
      background: "#000000", 
      display: "flex",
      gap: "12px",
      alignItems: "center"
    }}>
      <div style={{
        width: "70px",
        height: "70px",
        display: "flex",
        alignItems: "center",
        justifyContent: "center",
        background: "rgba(255,255,255,0.05)",
        borderRadius: "10px"
      }}>
        <img
          src={recommendation?.bestPick?.image}
          style={{ maxWidth: "100%", maxHeight: "100%", objectFit: "contain" }}
        />
      </div>

      <div>
        <a
          href={recommendation?.bestPick?.link}
          target="_blank"
          rel="noopener noreferrer"
          style={{
fontSize: "16px",
fontWeight: "600",
color: "#38bdf8",
lineHeight: "1.4",
            textDecoration: "none"
          }}
        >
          {recommendation?.bestPick?.name}
        </a>

        <div style={{ fontSize: "13px", color: "#94a3b8", marginTop: "2px" }}>
          Sold on <b>{recommendation?.bestPick?.source}</b>
        </div>

        <div style={{
          marginTop: "6px",
          fontSize: "15px",
          fontWeight: "600",
          color: "#f8fafc"
        }}>
          ${recommendation?.bestPick?.price}
          <span style={{ marginLeft: "10px", fontSize: "13px", color: "#f59e0b" }}>
            ⭐ {rating}
          </span>
        </div>
      </div>
    </div>

    {/* WHY */}
    <div style={{
  marginTop: "18px",
 // background: "rgba(255,255,255,0.03)",
 // padding: "14px",
//  borderRadius: "12px"
}}>

  <div style={{ 
    fontWeight: "600", 
    marginBottom: "10px",
    color: "#38bdf8",   // 🔵 blue highlight
    fontSize: "14px"
  }}>
    ✨ Why this stands out
  </div>

  <div style={{
    display: "flex",
    flexDirection: "column",
    gap: "6px",
    fontSize: "13px"
  }}>

    <div style={{ color: "#e2e8f0" }}>
      ✅ <span style={{ color: "#94a3b8" }}>Balanced price and performance</span>
    </div>

    <div style={{ color: "#facc15" }}>
      ⭐ <span style={{ color: "#94a3b8" }}>Strong user ratings</span>
    </div>

    <div style={{ color: "#60a5fa" }}>
      📦 <span style={{ color: "#94a3b8" }}>Reliable availability</span>
    </div>

  </div>

</div>
    {/* CONFIDENCE */}
    {confidence > 0 && (
      <div style={{
        fontSize: "13px",
        color: "#94a3b8",
        marginTop: "10px"
      }}>
        Confidence: {(confidence * 100).toFixed(0)}%
      </div>
    )}

    {/* CHEAPER OPTION */}
    {cheaper?.name && (
      <div style={{
        marginTop: "16px",
        padding: "12px",
        borderRadius: "12px",
        background: "#000000", 
		border: "1px solid rgba(34,197,94,0.4)",
        border: "1px solid #bbf7d0",
		title: "#22c55e",
		price: "#4ade80",
		link: "#86efac"
      }}>
        <div style={{
          fontSize: "12px",
          fontWeight: "600",
          color: "#16a34a",
          marginBottom: "6px"
        }}>
          💰 Cheaper Option
        </div>

        <a
          href={cheaper.link}
          target="_blank"
          rel="noopener noreferrer"
          style={{
            color: "#166534",
            fontWeight: "500",
            textDecoration: "none"
          }}
        >
          {cheaper.name}
        </a>

        <div style={{
          marginTop: "6px",
          fontSize: "13px",
          display: "flex",
          gap: "8px"
        }}>
          <span style={{ color: "#16a34a", fontWeight: "600" }}>
            ${cheaper.price}
          </span>
          <span style={{ color: "#94a3b8" }}>•</span>
          <span style={{ color: "#f59e0b" }}>
            ⭐ {Number(cheaper.rating || 3.5).toFixed(1)}
          </span>
        </div>

        <div style={{ fontSize: "12px", color: "#94a3b8", marginTop: "4px" }}>
          Sold on <b>{cheaper.source}</b>
        </div>
      </div>
    )}

    {/* SEGMENT + CTA */}
    <div style={{
      marginTop: "18px",
      display: "flex",
gap: "16px",
alignItems: "center",
justifyContent: "center",
textAlign: "left",
	  justifyContent: "space-between",
      flexWrap: "wrap",
      gap: "10px"
    }}>
      <div style={{
        display: "inline-flex",
        background: "#000000",
        borderRadius: "30px",
        padding: "4px",
        gap: "4px"
      }}>
        <div onClick={() => setMode("all")} style={{
          padding: "6px 14px",
          borderRadius: "20px",
          cursor: "pointer",
          fontSize: "13px",
          fontWeight: "600",
          background: mode === "all" ? "#e0f2fe" : "transparent",
          color: mode === "all" ? "#0284c7" : "#64748b",
		  //color: "#fff",
		        //  background: "#000000",
				maxWidth: "700px",
			margin: "0 auto",
        borderRadius: "30px"
        }}>
          All
        </div>

        <div onClick={() => setMode("best")} style={{
          padding: "6px 14px",
          borderRadius: "20px",
          cursor: "pointer",
          fontSize: "13px",
          fontWeight: "600",
          background: mode === "best" ? "#2563eb" : "transparent",
          color: mode === "best" ? "#fff" : "#2563eb"
        }}>
          Best
        </div>

        {cheaper && (
          <div onClick={() => setMode("cheap")} style={{
            padding: "6px 14px",
            borderRadius: "20px",
            cursor: "pointer",
            fontSize: "13px",
            fontWeight: "600",
            background: mode === "cheap" ? "#22c55e" : "transparent",
            color: mode === "cheap" ? "#fff" : "#22c55e"
          }}>
            Save
          </div>
        )}
      </div>

      {recUrl && (
        <a
          href={recUrl.startsWith("http") ? recUrl : `https://${recUrl}`}
          target="_blank"
          rel="noopener noreferrer"
          style={{
            padding: "10px 20px",
            //background: "linear-gradient(135deg, #0ea5e9, #2563eb)",
            color: "#fff",
            borderRadius: "999px",
            textDecoration: "none",
            fontWeight: "600",
            fontSize: "14px"
          }}
        >
          View Product →
        </a>
      )}
    </div>

  </div>
);
}