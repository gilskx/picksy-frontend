"use client";

export default function CompareBar({
  compareList,
  setShowComparePage
}: any) {

  if (!compareList || compareList.length < 2) return null;

  return (
    <div style={{
      position: "fixed",
      bottom: "20px",
      left: "50%",
      transform: "translateX(-50%)",
        background: "#000000", 
      padding: "12px 20px",
      borderRadius: "40px",
      boxShadow: "0 10px 30px rgba(0,0,0,0.2)",
      display: "flex",
      alignItems: "center",
      gap: "15px",
      zIndex: 999
    }}>
      <span style={{ fontSize: "14px", fontWeight: "500" }}>
        {compareList.length} items selected
      </span>

      <button
        onClick={() => setShowComparePage(true)}
        style={{
          padding: "10px 18px",
          borderRadius: "25px",
          background: "linear-gradient(135deg, #6366f1, #a855f7)",
          color: "#fff",
          border: "none",
          fontWeight: "600",
          cursor: "pointer"
        }}
      >
        Compare Now →
      </button>
    </div>
  );
}