"use client";

export default function HeroRecommendation({ recommendation, confidence }: any) {
  if (!recommendation?.bestPick) return null;

  const p = recommendation.bestPick;

  const rating = p.rating || 4.5;

  return (
    <div style={{
      width: "100%",
      maxWidth: "1000px",
      margin: "0 auto",
      marginTop: "40px"
    }}>

      {/* HEADER */}
      <div style={{ textAlign: "center", marginBottom: "30px" }}>
        <div style={{ color: "#38bdf8", fontSize: "14px" }}>
          ✨ Smart Buy
        </div>

        <div style={{
          fontSize: "32px",
          fontWeight: "700",
          color: "#fff"
        }}>
          Best choice for your search
        </div>

        <div style={{
          fontSize: "14px",
          color: "#94a3b8"
        }}>
          Based on price, performance, ratings & availability
        </div>
      </div>

      {/* HERO CARD */}
      <div style={{
        borderRadius: "24px",
        padding: "40px",
        background: `
          radial-gradient(circle at 70% 50%, rgba(59,130,246,0.35), transparent 40%),
          linear-gradient(135deg, #0f172a, #020617)
        `,
        boxShadow: "0 25px 80px rgba(0,0,0,0.7)",
        border: "1px solid rgba(255,255,255,0.08)"
      }}>

        <div style={{
          display: "flex",
          justifyContent: "space-between",
          alignItems: "center",
          gap: "30px",
          flexWrap: "wrap"
        }}>

          {/* LEFT */}
          <div style={{ flex: 1 }}>

            <div style={{
              background: "rgba(251,191,36,0.15)",
              color: "#facc15",
              display: "inline-block",
              padding: "6px 12px",
              borderRadius: "20px",
              fontSize: "12px",
              marginBottom: "10px"
            }}>
              🏆 Best Recommendation
            </div>

            <div style={{
              fontSize: "26px",
              fontWeight: "700",
              color: "#fff"
            }}>
              {p.name}
            </div>

            <div style={{
              marginTop: "8px",
              color: "#94a3b8",
              fontSize: "14px",
              maxWidth: "400px"
            }}>
              Premium product selected based on value, rating and performance
            </div>

            <div style={{
              marginTop: "14px",
              fontSize: "28px",
              fontWeight: "700",
              color: "#fff"
            }}>
              ${p.price}

              <span style={{
                marginLeft: "10px",
                fontSize: "16px",
                color: "#f59e0b"
              }}>
                ⭐ {rating}
              </span>
            </div>

            <a
              href={p.link}
              target="_blank"
              style={{
                display: "inline-block",
                marginTop: "18px",
                padding: "12px 24px",
                borderRadius: "30px",
                background: "linear-gradient(135deg, #6366f1, #3b82f6)",
                color: "#fff",
                textDecoration: "none",
                fontWeight: "600",
                boxShadow: "0 10px 30px rgba(59,130,246,0.5)"
              }}
            >
              View on Amazon →
            </a>

          </div>

          {/* RIGHT */}
          <div style={{
            flex: 1,
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            gap: "20px"
          }}>

            {/* IMAGE */}
            <div style={{ position: "relative" }}>
              <div style={{
                position: "absolute",
                bottom: "-10px",
                left: "50%",
                transform: "translateX(-50%)",
                width: "200px",
                height: "50px",
                background: "radial-gradient(circle, rgba(59,130,246,0.6), transparent 70%)",
                filter: "blur(20px)"
              }} />

              <img
                src={p.image}
                style={{
                  maxWidth: "260px",
                  objectFit: "contain",
                  filter: "drop-shadow(0 20px 40px rgba(0,0,0,0.8))"
                }}
              />
            </div>

            {/* THUMBNAILS */}
            <div style={{
              display: "flex",
              flexDirection: "column",
              gap: "10px"
            }}>
              {[1,2,3].map(i => (
                <div key={i} style={{
                  width: "50px",
                  height: "50px",
                  borderRadius: "12px",
                  background: "rgba(255,255,255,0.05)",
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "center"
                }}>
                  <img src={p.image} style={{ maxWidth: "80%" }} />
                </div>
              ))}
            </div>

          </div>
        </div>

        {/* WHY SECTION */}
        <div style={{
          display: "flex",
          justifyContent: "center",
          gap: "15px",
          marginTop: "30px",
          flexWrap: "wrap"
        }}>
          {[
            "Balanced price & performance",
            "Strong user ratings",
            "Reliable availability",
            `Confidence: ${(confidence * 100).toFixed(0)}%`
          ].map((t, i) => (
            <div key={i} style={{
              background: "rgba(255,255,255,0.05)",
              padding: "10px 16px",
              borderRadius: "20px",
              color: "#e2e8f0",
              fontSize: "13px"
            }}>
              {t}
            </div>
          ))}
        </div>

      </div>
    </div>
  );
}