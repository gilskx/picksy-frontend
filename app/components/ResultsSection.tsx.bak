"use client";
import AIWaveLoader from "./AIWaveLoader";
import ProductCard from "./ProductCard";
import "./globals.css";
import { useState, useEffect, useRef } from "react";

export default function ResultsSection({
  loading,
  query,
  displayProducts,
  recommendation,
  cheaper,
  bestDeal,
  compareList,
  setCompareList,
  setShowComparePage,
  hasSearched,
  mode,
  setMode,
  searchInResults,
  setSearchInResults,
  minPrice,
  setMinPrice,
  maxPrice,
  setMaxPrice,
  sortBy,
  setSortBy,
   loadingMessage 
}: any) {
 
 
// ✅ ONLY AFTER ALL HOOKS
//if (!hasSearched && !loading) return null;

  


   

// ✅ FILTER + SORT LOGIC (ADD HERE)
let filteredProducts = displayProducts || [];

// 🔎 SEARCH FILTER
if (searchInResults) {
  filteredProducts = filteredProducts.filter((p: any) =>
    p.name?.toLowerCase().includes(searchInResults.toLowerCase())
  );
}

// 💰 PRICE FILTER
if (minPrice) {
  filteredProducts = filteredProducts.filter(
    (p: any) => p.price && p.price >= Number(minPrice)
  );
}

if (maxPrice) {
  filteredProducts = filteredProducts.filter(
    (p: any) => p.price && p.price <= Number(maxPrice)
  );
}

// 🔄 SORTING
if (sortBy === "priceLow") {
  filteredProducts.sort((a: any, b: any) => a.price - b.price);
} else if (sortBy === "priceHigh") {
  filteredProducts.sort((a: any, b: any) => b.price - a.price);
} else if (sortBy === "rating") {
  filteredProducts.sort((a: any, b: any) => b.rating - a.rating);
}








return (
  <div className="nokku-results-section" style={{
    width: "100%",
    maxWidth: "1200px",
    margin: "20px auto",          // 🔥 center whole block
    padding: "24px",
    borderRadius: "12px",
    
 
  }}>

      {/* HEADER */}
     {!loading && (
  <div style={{
    marginBottom: "16px",
    display: "flex",
    alignItems: "center",
    justifyContent: "space-between"
  }}>
        <div style={{
  display: "flex",
  alignItems: "center",
  gap: "10px"
}}>
          <span style={{ fontSize: "18px" }}>🔍</span>

          <div>
            <div style={{
              fontSize: "14px",
              fontWeight: "500",
              color: "rgba(34,193,255,0.75)",
            }}>
              More options recommended by nokku.ai for you "{query}" - {displayProducts.length} Products and enables comparison across leading brands — instantly
            </div>

          </div>
        </div>
      </div>
)}
      {/* 🔥 FILTER TABS (NEW) */}
      {/* 🔥 FILTER BAR */}
{!loading && hasSearched && (
  <div style={{
    display: "flex",
     justifyContent: "center", 
    alignItems: "center",
    gap: "70px",
    marginBottom: "20px"
  }}>

    
	{/* 🔲 BUTTON BOX */}
    <div style={{
      display: "flex",
      gap: "10px",
      padding: "10px",
      borderRadius: "12px",
background: "rgba(59,130,246,0.12)",   // soft blue fill
border: "1px solid rgba(59,130,246,0.35)", // blue border
boxShadow: "0 10px 30px rgba(59,130,246,0.25)"
     
    }}>
      {["all", "best", "cheap"].map((m) => (
  <div
    key={m}
    onClick={() => setMode(m)}
    style={{
      padding: "8px 16px",
      borderRadius: "20px",
      cursor: "pointer",
      fontSize: "13px",
      fontWeight: "600",

      // 🔥 SAME BACKGROUND FOR ALL (ACTIVE vs INACTIVE)
     background: "rgba(255,255,255,0.05)",

color: "#22c1ff",

border:
  mode === m
    ? "1px solid rgba(59,130,246,0.8)"   // 🔥 active highlight
    : "1px solid rgba(255,255,255,0.1)",

      // 🔥 SAME BORDER FOR ALL
     
      transition: "all 0.25s ease"
    }}
    onMouseOver={(e) => {
      e.currentTarget.style.transform = "scale(1.05)";
    }}
    onMouseOut={(e) => {
      e.currentTarget.style.transform = "scale(1)";
    }}
  >
    {m === "all" ? "All" : m === "best" ? "Best" : "Save 💰"}
  </div>
))}
    </div>

    {/* 🔲 FILTER BOX */}
    
	<div style={{
  display: "flex",
  gap: "10px",
  flexWrap: "wrap",
  alignItems: "center",
  justifyContent: "center",
  padding: "10px",
  borderRadius: "12px",
  background: "rgba(59,130,246,0.12)",
  border: "1px solid rgba(59,130,246,0.35)",
  boxShadow: "0 10px 30px rgba(59,130,246,0.25)"
}}>

  {/* 🔥 COMMON STYLE */}
  {(() => {
    const commonStyle = {
      padding: "8px 14px",
      borderRadius: "25px",
      border: "1px solid rgba(59,130,246,0.35)",
      background: "rgba(59,130,246,0.12)",
      color: "rgba(226, 232, 240, 0.75)",
      outline: "none",

      // 🔥 FORCE REMOVE DEFAULT INPUT STYLES
      appearance: "none" as any, 
      WebkitAppearance: "none" as any,
      MozAppearance: "none" as any,

      // 🔥 FORCE TEXT RENDERING (IMPORTANT)
      WebkitTextFillColor: "#e2e8f0"
    };

    return (
      <>
        {/* SEARCH */}
        <input
          placeholder="Search for product"
          value={searchInResults}
          onChange={(e) => setSearchInResults(e.target.value)}
          style={{
            ...commonStyle,
            minWidth: "180px"
          }}
        />

        {/* MIN */}
        <input
          placeholder="Min Price"
          value={minPrice}
          onChange={(e) => setMinPrice(e.target.value)}
          style={{
            ...commonStyle,
            width: "120px"
          }}
        />

        {/* MAX */}
        <input
          placeholder="Max Price"
          value={maxPrice}
          onChange={(e) => setMaxPrice(e.target.value)}
          style={{
            ...commonStyle,
            width: "120px"
          }}
        />

        {/* SORT */}
        <select
          value={sortBy}
          onChange={(e) => setSortBy(e.target.value)}
          style={{
            ...commonStyle,
            cursor: "pointer",
            minWidth: "160px"
          }}
        >
          <option value="best">Best Match</option>
          <option value="priceLow">Price: Low to High</option>
          <option value="priceHigh">Price: High to Low</option>
          <option value="rating">Top Rated</option>
        </select>
      </>
    );
  })()}

</div>

{/* 🔥 FORCE OVERRIDE GLOBAL CSS */}
<style jsx>{`
  input,
  select {
    background: rgba(59,130,246,0.12) !important;
    color: #e2e8f0 !important;
    border: 1px solid rgba(59,130,246,0.35) !important;
  }

  input::placeholder {
    color: rgba(226, 232, 240, 0.6) !important;
  }
`}</style>
	
	  {/* Filter Box Ebs */}

  </div>
)}
      {/* LOADING / EMPTY / GRID */}
{loading ? (
  <div style={{ textAlign: "center", padding: "40px 0" }}>

    {/* 🌊 AI WAVE */}
    <div style={{
  position: "relative",
  width: "200px",
  height: "120px",
  margin: "0 auto"
}}>


  {/* 🌊 WAVE CENTER */}
  <div style={{
    position: "absolute",
    top: "50%",
    left: "50%",
    transform: "translate(-50%, -50%)"
  }}>
    <AIWaveLoader />
  </div>



</div>

    {/* 🔤 STAGE TEXT */}
    <div style={{
      marginTop: "20px",
      fontSize: "15px",
      color: "rgba(34, 193, 255, 0.75)",
      fontWeight: "500"
    }}>
      {loadingMessage}
    </div>

 

    {/* OPTIONAL: QUERY "{query}" - removed */}
    <div style={{
      marginTop: "6px",
      fontSize: "12px",
      color: "#475569"
    }}>
      
    </div>

  </div>
) : !loading && filteredProducts.length === 0 ? (

  <div style={{
    padding: "60px 20px",
    textAlign: "center"
  }}>
    <div style={{ fontSize: "40px", marginBottom: "10px" }}>🔍</div>

    <div style={{
      fontSize: "18px",
      fontWeight: "600",
      color: "#f8fafc",
      marginBottom: "6px"
    }}>
      No results found
    </div>

    <div style={{
      fontSize: "14px",
      color: "#94a3b8"
    }}>
      Try a different search or adjust your filters
    </div>
  </div>

) : (

  <div className="nokku-results-grid" style={{
  display: "grid",
  gridTemplateColumns: "repeat(auto-fit, minmax(250px, 1fr))",
    gap: "24px"
  }}>
    {filteredProducts.slice(0, 12).map((p: any, i: number) => (
      <ProductCard
        key={i}
        p={p}
        recommendation={recommendation}
        cheaper={cheaper}
        bestDeal={bestDeal}
        compareList={compareList}
        setCompareList={setCompareList}
        setShowComparePage={setShowComparePage}
      />
    ))}
  </div>

)}

    </div>
  );
}	