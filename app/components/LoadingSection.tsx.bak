"use client";
import "./globals.css";

export default function LoadingSection({ loading, loadingMessage }: any) {

  // 🔥 FIX: allow rendering even if loading prop is not passed
  if (loading === false) return null;

  return (
    <>
      {/* 🔥 AI MESSAGE PANEL */}
      <div style={{
        background: "#000000",
        padding: "18px",
        borderRadius: "12px",
        marginBottom: "20px",
        boxShadow: "0 6px 20px rgba(0,0,0,0.08)",
        borderLeft: "5px solid #2c7be5",
        color: "#e2e8f0"   // ✅ FIX: text visible on dark bg
      }}>
        <div style={{
          fontWeight: "600",
          fontSize: "15px"
        }}>
          🤖 Picksy AI is working...
        </div>

        <div style={{
          marginTop: "10px",
          fontSize: "14px",
          color: "#cbd5f5"   // ✅ FIX: readable text
        }}>
          {loadingMessage || "Loading..."}
        </div>
      </div>

      {/* 🔥 SKELETON CARDS */}
      <div style={{
        display: "grid",
        gridTemplateColumns: "repeat(auto-fill, minmax(220px, 1fr))",
        gap: "20px"
      }}>
        {[...Array(6)].map((_, i) => (
          <div key={i} style={{
            background: "#020617",
            borderRadius: "16px",
            padding: "14px",
            boxShadow: "0 10px 25px rgba(0,0,0,0.2)",
            border: "1px solid rgba(255,255,255,0.05)"
          }}>
            {/* IMAGE */}
            <div style={{
              height: "120px",
              background: "linear-gradient(90deg, #1e293b, #334155, #1e293b)",
              borderRadius: "8px",
              animation: "pulse 1.5s infinite"
            }} />

            {/* TITLE */}
            <div style={{
              height: "12px",
              background: "linear-gradient(90deg, #1e293b, #334155, #1e293b)",
              marginTop: "10px",
              borderRadius: "6px",
              width: "80%",
              animation: "pulse 1.5s infinite"
            }} />

            {/* SUBTITLE */}
            <div style={{
              height: "12px",
              background: "linear-gradient(90deg, #1e293b, #334155, #1e293b)",
              marginTop: "6px",
              borderRadius: "6px",
              width: "60%",
              animation: "pulse 1.5s infinite"
            }} />
          </div>
        ))}
      </div>

      {/* 🔥 ANIMATION */}
      <style>
        {`
          @keyframes pulse {
            0% { opacity: 0.6; }
            50% { opacity: 1; }
            100% { opacity: 0.6; }
          }
        `}
      </style>
    </>
  );
}