"use client";
import { useState } from "react";
export default function HeroRecommendation({
  recommendation,
  confidence,
  cheaper,
  recUrl,
  aiActive,
  mode,
  setMode
}: any) {

  if (!recommendation?.bestPick) return null;

  const p = recommendation.bestPick;
  const rating = p.rating || 4.5;
  const [showAIChat, setShowAIChat] = useState(false);		
  const [aiQuestion, setAiQuestion] = useState("");
const [aiAnswer, setAiAnswer] = useState("");
const [aiLoading, setAiLoading] = useState(false);

  // 🔥 NEW: Dynamic source detection
  const getDomainName = (url: string) => {
    try {
      const hostname = new URL(url).hostname;
      return hostname
        .replace("www.", "")
        .split(".")[0]
        .replace(/^\w/, (c) => c.toUpperCase());
    } catch {
      return "Store";
    }
  };

  const sourceName = p.source
  ? p.source.replace(/^\w/, (c: string) => c.toUpperCase())
  : getDomainName(p.link);
    : getDomainName(p.link);
	const askAI = async () => {
  if (!aiQuestion) {
  alert("Please enter a question");
  return;
}

  try {
    setAiLoading(true);
    setAiAnswer("");

    const res = await fetch("https://basket-pellet-constable.ngrok-free.dev/api/ask-product", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        question: aiQuestion,
        product: p.name
      })
    });

    const data = await res.json();
    setAiAnswer(data.answer);

  } catch (e) {
    console.error(e);
    setAiAnswer("⚠️ Failed to get AI response");
  } finally {
    setAiLoading(false);
  }
};

  return (
